CREATE COMPUTE MODULE getFetch_Compute1
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		CREATE FIELD OutputRoot.JSON.Data IDENTITY(JSON.Array)Data;
		DECLARE apiRef REFERENCE TO InputRoot.JSON.Data.children.Item[1];
		DECLARE i INTEGER 1;
		WHILE LASTMOVE(apiRef) DO
			SET OutputRoot.JSON.Data.Item[i] = apiRef.name;
			SET i = i + 1;
			MOVE apiRef NEXTSIBLING;
		END WHILE;
		RETURN TRUE;
	END;

END MODULE;
