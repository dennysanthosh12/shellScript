ruleset(name="remote") {

    # Exclude 200 and 100
    if not re_match($msg, "RespCode=(200|100)") then {
        action(type="omfile" file="/var/log/non_success.log")
        stop
    }

    # Optional: log success separately
    if re_match($msg, "RespCode=(200|100)") then {
        action(type="omfile" file="/var/log/success.log")
        stop
    }
}
