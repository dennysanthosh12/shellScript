<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<mappingRoot xmlns="http://www.ibm.com/2008/ccl/Mapping" 
             xmlns:map="default" 
             domainID="com.ibm.msl.mapping.xml" 
             domainIDExtension="mb" 
             mainMap="true" 
             targetNamespace="default" 
             version="8.0.5.0">

    <inlinedXMLSchema>
        <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">

  <xsd:element name="ERROR" nillable="true">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element maxOccurs="1" minOccurs="0" name="Message" nillable="true" type="xsd:string"/>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>

  <xsd:element name="RESPONSE" nillable="true" type="xsd:string"/>

</xsd:schema>
]]>
    </inlinedXMLSchema>

    <!-- Input: your message schema (Cache.xsd with input/Rows) -->
    <input path="/Cache.xsd" var="var2"/>

    <!-- Input: IBM internal cache XSD for CacheFailure -->
    <input path="jar:file://!com/ibm/msl/mapping/cache/xsds/cache.xsd" var="var3"/>

    <!-- Input: inlined schema for RESPONSE/ERROR type resolution -->
    <input inlinedXMLSchema="true" path="../schema_1.xsd" var="var5"/>

    <!-- Output: JSON domain message -->
    <output path="jar:file://!com/ibm/etools/mft/map/xsds/predefined/JsonDomainMsg.xsd" var="var4"/>

    <!-- Output: IBM cache XSD for CachePut -->
    <output path="jar:file://!com/ibm/msl/mapping/cache/xsds/cache.xsd" var="var"/>

    <namespaces>
        <namespace kind="supplement" prefix="io" uri="http://www.ibm.com/msl/cache/1.0"/>
        <namespace kind="supplement" prefix="out" uri="http://www.ibm.com/iib/msl/json"/>
    </namespaces>

    <generation engine="xquery"/>

    <mappingDeclaration name="getFetch_Mapping">

        <!-- Input message assembly from XMLNSC domain -->
        <input path="$var2/mb:msg(input,assembly,XMLNSC,Properties)" var="MessageAssembly"/>

        <!-- Output message assembly to JSON domain -->
        <output namespace="http://www.ibm.com/iib/msl/json" 
                path="$var4/mb:msg(JSON,assembly,JSON,Properties)" 
                var="MessageAssembly2">

            <!-- Cast Data root as JSONObject -->
            <cast castType="userDefined" 
                  path="$MessageAssembly2/JSON/Data/type('anyType')" 
                  qualifier="{http://www.ibm.com/iib/msl/json}JSONObject" 
                  ref="var4"/>

            <!-- Cast array slot 2 for RESPONSE type — separate spath index -->
            <cast castType="userDefined" 
                  path="$MessageAssembly2/JSON/spath('Data',2)/any" 
                  qualifier="RESPONSE" 
                  ref="var5"/>

            <!-- Cast array slot 3 for ERROR type — separate spath index -->
            <cast castType="userDefined" 
                  path="$MessageAssembly2/JSON/spath('Data',3)/any" 
                  qualifier="ERROR" 
                  ref="var5"/>

        </output>

        <!-- Propagate Properties from input to output -->
        <move>
            <input path="$MessageAssembly/Properties"/>
            <output path="$MessageAssembly2/Properties"/>
        </move>

        <!-- Loop over each Row in the input -->
        <foreach>
            <input path="$MessageAssembly/input/Rows" var="Rows1"/>
            <output path="$MessageAssembly2/JSON/spath('Data',2)"/>

            <!-- Cache PUT transaction -->
            <transaction>
                <cachePut>
                    <input path="$Rows1/."/>
                    <output path="$var/CachePut" var="CachePut"/>
                    <!-- FIX: fully anchored input and output paths -->
                    <move>
                        <input path="$Rows1/field_name"/>
                        <output path="$CachePut/Key"/>
                    </move>
                    <move>
                        <input path="$Rows1/field_value"/>
                        <output path="$CachePut/Value"/>
                    </move>
                </cachePut>

                <!-- On cache failure, write ERROR to output array -->
                <cacheFailure>
                    <input path="$var3/CacheFailure" var="CacheFailure"/>
                    <output path="$MessageAssembly2/JSON/spath('Data',3)/ERROR" var="ERROR"/>
                    <move>
                        <input path="$CacheFailure/Message"/>
                        <output path="$ERROR/Message"/>
                    </move>
                </cacheFailure>
            </transaction>

            <!-- On cache success, write RESPONSE to output array -->
            <assign value="SUCCESS">
                <output path="$MessageAssembly2/JSON/spath('Data',2)/RESPONSE"/>
            </assign>

        </foreach>

    </mappingDeclaration>

</mappingRoot>
