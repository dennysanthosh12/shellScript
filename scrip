FROM rhel:9.6

ENV ACE_HOME=/opt/IBM/ace
ENV PATH=$ACE_HOME/server/bin:$PATH

RUN mkdir -p /opt/IBM
RUN mkdir -p /opt/IBM/ace
RUN mkdir -p /home/aceuser/workdir
RUN mkdir -p /opt/IBM/EndPoint_Public
RUN mkdir -p /opt/IBM/RSAKeystore
RUN mkdir -p /opt/IBM/Keystore

COPY ./Broker_Properties /opt/IBM/
ENV ODBCINI /home/aceuser/workdir/odbc.ini
ENV ODBCSYSINI /opt/IBM/Broker_Properties/ODBC/unixodbc


WORKDIR /home/aceuser

EXPOSE 7600
EXPOSE 4001

CMD ["/bin/bash", "-c", "source mqsiprofile && IntegrationServer --work-dir /home/aceuser/workdir"]


#!/bin/bash

source mqsiprofile

WORK_DIR=/home/aceuser/workdir

echo "Checking work directory..."

# Check if already initialized
if [ ! -f "$WORK_DIR/server.conf.yaml" ]; then
  echo "Workdir not initialized. Creating..."
  mqsicreateworkdir "$WORK_DIR"
else
  echo "Workdir already exists. Skipping creation."
fi

echo "Starting Integration Server: ${SERVER_NAME}"

IntegrationServer \
  --work-dir "$WORK_DIR" \
  --name "${SERVER_NAME}"
