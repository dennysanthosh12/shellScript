

CREATE COMPUTE MODULE postVote_Compute1
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
	CREATE LASTCHILD OF OutputRoot DOMAIN 'JSON';
    SET OutputLocalEnvironment.Destination.HTTP.ReplyStatusCode = 400;

    DECLARE ref REFERENCE TO InputExceptionList.*[1];
    MOVE ref FIRSTCHILD;
    DECLARE i INTEGER 1;

    WHILE LASTMOVE(ref) DO
    	
    	IF ref.Number IS NOT NULL THEN
    		SET OutputRoot.Json.Data.ErrorCode = CAST(ref.Number AS CHARACTER CCSID COALESCE(InputRoot.Properties.CodedCharSetId ,1208));
    	END IF;
    	
        IF ref.Insert[5].Text IS NOT NULL THEN
            SET OutputRoot.JSON.Data.Error[1].errMsg =
            'BIP' || CAST(ref.Number AS CHARACTER);
        END IF;

        IF ref.Insert[6].Text IS NOT NULL THEN
            SET OutputRoot.JSON.Data.Error[1].errField = ref.Text;
        END IF;

        MOVE ref LASTCHILD;

    END WHILE;

    SET OutputRoot.JSON.Data.status = 400;


	RETURN TRUE;
	END;
END MODULE;
