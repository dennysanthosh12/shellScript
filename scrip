[eisuser@eisuatsftp01 INTEGRATION_SERVER]$ cat entrypoint.sh
#!/bin/bash

source /opt/IBM/ace/server/bin/mqsiprofile

# Create work directory only if it doesn't already exist
if [ ! -d "/var/mqsi/${SERVER_NAME}" ]; then
    echo "Creating work directory for ${SERVER_NAME}..."
    mqsicreateworkdir /var/mqsi/${SERVER_NAME}
    ibmint specify jre --version 8 --work-directory /var/mqsi/${SERVER_NAME}
    if [ -n "$ADMIN_USER" ] && [ -n "$ADMIN_PASS" ]; then
       echo "Creating Web Admin User"
       mqsiwebuseradmin -w /var/mqsi/${SERVER_NAME} -c -u ${ADMIN_USER} -a ${ADMIN_PASS"} -r iibadmin
    fi
else
    echo "Work directory /var/mqsi/${SERVER_NAME} already exists, skipping creation..."
fi

# Start Integration Server
exec IntegrationServer --work-dir /var/mqsi/${SERVER_NAME} \
    --name "${SERVER_NAME}" \
    --overrides-directory "${OVERRIDE_PATH}"
	
