CREATE COMPUTE MODULE postRequest_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE Amount INTEGER ;
		CREATE LASTCHILD OF OutputRoot DOMAIN 'DFDL';
		SET OutputRoot.DFDL.Request.header.RRN = InputRoot.JSON.Data.URN;
		SET OutputRoot.DFDL.Request.body.Amount = InputRoot.JSON.Data.Amount;
		SET OutputRoot.DFDL.Request.body.Name = InputRoot.JSON.Data.Name;
		SET OutputRoot.DFDL.Request.body.Age = InputRoot.JSON.Data.Age;
		
		RETURN TRUE;

	END;
END MODULE;


