        <xsd:element dfdl:initiator="[b]" dfdl:lengthKind="delimited" dfdl:occursCountKind="implicit" maxOccurs="unbounded" name="body">
                                        					
          
          
          
          <xsd:complexType>
                                                						
            
            
            
            <xsd:sequence>
                                                        							
              
              
              
