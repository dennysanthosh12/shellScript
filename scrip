CREATE COMPUTE MODULE postHit_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN

		CALL CopyEntireMessage();
		DECLARE env REFERENCE TO Environment;
		
		SET env.mgsint = ASBITSTREAM(InputRoot.JSON.Data ENCODING InputRoot.Properties.Encoding CCSID COALESCE(InputRoot.Properties.CodedCharSetId,1208));
		SET env.msgstr = CAST(env.mgsint AS CHARACTER ENCODING InputRoot.Properties.Encoding CCSID COALESCE(InputRoot.Properties.CodedCharSetId,1208));
		
		RETURN TRUE;
	END;


	CREATE PROCEDURE CopyEntireMessage() BEGIN
		SET OutputRoot = InputRoot;
	END;
END MODULE;
