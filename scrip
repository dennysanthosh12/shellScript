

CREATE COMPUTE MODULE postUpdate_Compute3
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE Env REFERENCE to Environment;
		DECLARE EnvVal REFERENCE TO Environment.XMLNSC.Validation;
		SET Env.Flag=COALESCE(Env.Flag,'Y');
		
		IF Env.Flag='N' THEN
			DECLARE outRef REFERENCE TO Environment.XMLNSC.Validation.File[1];
			CREATE LASTCHILD OF OutputRoot DOMAIN('XMLNSC');
			CREATE LASTCHILD OF OutputRoot.XMLNSC NAME 'Validation';
			DECLARE outXmRef REFERENCE TO OutputRoot.XMLNSC.Validation;
		    WHILE LASTMOVE(outRef) DO
		    	CREATE LASTCHILD OF outXmRef NAME 'File';
		    	DECLARE fileRef REFERENCE TO outXmRef LASTCHILD;
		    	SET fileRef.Filename = outRef.FileName;
		    	SET fileRef.FileContent = outRef.FileContent ;
		    	MOVE fileRef NEXTSIBLING;
			END WHILE;
			RETURN true;
		ELSE
			CREATE LASTCHILD OF EnvVal NAME 'File';
			DECLARE fileRef REFERENCE TO EnvVal LASTCHILD;
			SET fileRef.FileName = InputLocalEnvironment.File.Read.Name;
			CREATE LASTCHILD OF fileRef NAME 'FileContent';
			DECLARE contentRef REFERENCE TO fileRef LASTCHILD;
			CREATE LASTCHILD OF contentRef DOMAIN 'XMLNSC' PARSE(InputRoot.BLOB.BLOB ENCODING InputRoot.Properties.Encoding CCSID InputRoot.Properties.CodedCharSetId);
			SET Env.i=Env.i+1;
			RETURN false;
		END IF;
	END;
END MODULE;
