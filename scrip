CREATE COMPUTE MODULE inbCustomerEnquiry_sys_Compute2
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE Env REFERENCE TO Environment;
		--SET OutputRoot.JSON.Data.abcfsFAS = Environment.RESP_FLAG;
		IF Environment.RES_FLAG = 'Y' THEN
			SET Environment.RESPONSE_STATUS = '1';
			SET OutputRoot.JSON.Data.ERROR_CODE = COALESCE(Environment.ERROR_CODE, InputRoot.JSON.Data.ERROR_CODE);
			SET OutputRoot.JSON.Data.ERROR_DESCRIPTION = COALESCE(Environment.ERROR_DESCRIPTION, InputRoot.JSON.Data.ERROR_DESCRIPTION);
			SET OutputRoot.JSON.Data.RESPONSE_STATUS = '1';
		ELSE
			IF Environment.INBFEJNO <> Environment.CBS_MSG_ID THEN
				SET Environment.RESPONSE_STATUS = '1';
				SET Environment.ERROR_CODE = 'SI163';
				SET Environment.ERROR_DESCRIPTION = 'JOURNAL NUMBER MISMATCH';
			END IF;

			IF Environment.RESPONSE_STATUS = '0' THEN
				SET OutputRoot = InputRoot;
				SET Environment.RESPONSE_STATUS = '0';
				SET OutputRoot.JSON.Data.ERROR_CODE VALUE = '';
				SET OutputRoot.JSON.Data.ERROR_DESCRIPTION VALUE = '';
				SET OutputRoot.JSON.Data.RESPONSE_STATUS = '0';
			ELSE
				SET Environment.RESPONSE_STATUS = '1';
				SET OutputRoot.JSON.Data.ERROR_CODE = COALESCE(Environment.ERROR_CODE, InputRoot.JSON.Data.ERROR_CODE);
				SET OutputRoot.JSON.Data.ERROR_DESCRIPTION = COALESCE(Environment.ERROR_DESCRIPTION, InputRoot.JSON.Data.ERROR_DESCRIPTION);
				SET OutputRoot.JSON.Data.RESPONSE_STATUS = '1';

			END IF;
		END IF;

		SET OutputRoot.JSON.Data.RESPONSE_DATE = CAST(CURRENT_TIMESTAMP AS CHARACTER FORMAT 'dd-MM-yyyy HH:mm:ss');
		SET OutputRoot.JSON.Data.REQUEST_REFERENCE_NUMBER = Environment.REQUEST_REFERENCE_NUMBER;
		RETURN TRUE;
	END;
END MODULE;


