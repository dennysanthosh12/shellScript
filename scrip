---
- name: LINUX_SCD
  hosts: 'Server_Group_3'
  become: true
  gather_facts: no

  vars:
    ssh_config:
      - { regex: '^#?Protocol', line: 'Protocol 2' }
      - { regex: '^#?PermitRootLogin', line: 'PermitRootLogin no' }
      - { regex: '^#?PermitEmptyPasswords', line: 'PermitEmptyPasswords no' }
      - { regex: '^#?X11Forwarding', line: 'X11Forwarding no' }
      - { regex: '^#?MaxAuthTries', line: 'MaxAuthTries 4' }
      - { regex: '^#?ClientAliveInterval', line: 'ClientAliveInterval 300' }
      - { regex: '^#?ClientAliveCountMax', line: 'ClientAliveCountMax 0' }
      - { regex: '^#?LoginGraceTime', line: 'LoginGraceTime 60' }
      - { regex: '^#?Banner', line: 'Banner /etc/issue.net' }
  tasks:
    - name: Set ownership and permission for sshd_config
      file:
        path: /etc/ssh/sshd_config
        owner: root
        group: root
        mode: '0600'
      register: output1
      tags: SSH_SUP

    - name: Configure SSH parameters
      lineinfile:
        path: /etc/ssh/sshd_config
        regexp: "{{ item.regex }}"
        line: "{{ item.line }}"
        state: present
      loop: "{{ ssh_config }}"
      register: output2
      tags: SSH_SUP

    - name: Restrict SSH users
      lineinfile:
        path: /etc/ssh/sshd_config
        line: "AllowUsers admin"
      register: output3
      tags: SSH_SUP

    - name: Restart SSH service
      service:
        name: sshd
        state: restarted
      register: output4
      tags: SSH_SUP

    - name: Output of All Tags SSH_SUP
      debug:
        msg:
          -"Output1: {{ output1 }}"
          -"Output2: {{ output2 }}"
          -"Output3: {{ output3 }}"
          -"Output4: {{ output4 }}"




