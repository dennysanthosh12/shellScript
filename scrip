DECLARE TCPOutputTimeOut EXTERNAL INTEGER 5;
DECLARE TCPReceiveTimeOut EXTERNAL INTEGER 5;

CREATE COMPUTE MODULE accountBalanceEnquiry_E0_MR_sys_Request
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		SET OutputLocalEnvironment.Destination.TCPIP.Output.Timeout = TCPOutputTimeOut;
		SET OutputLocalEnvironment.TCPIP.Receive.Timeout = TCPOutputTimeOut;
		SET Environment.REQUEST_REFERENCE_NUMBER = InputRoot.JSON.Data.REQUEST_REFERENCE_NUMBER;
		SET OutputRoot = InputRoot;
		
			   DECLARE Env REFERENCE TO Environment; 
		       
		       SET Environment.RESPONSE_STATUS = '0'; 
		        
	           SET OutputRoot.DFDL.Request.body.MetaData1 = ' ';
	           SET OutputRoot.DFDL.Request.body.PROTOCOL_ID = InputRoot.JSON.Data.PROTOCOL_ID;
	           SET OutputRoot.DFDL.Request.body.TRANSACTION_TYPE = InputRoot.JSON.Data.TRANSACTION_TYPE;
	           SET OutputRoot.DFDL.Request.body.PRODUCT_CODE =  InputRoot.JSON.Data.PRODUCT_CODE;
	           SET OutputRoot.DFDL.Request.body.BRANCH_CODE = InputRoot.JSON.Data.BRANCH_CODE;
	           SET OutputRoot.DFDL.Request.body.REFERENCE_NUMBER = InputRoot.JSON.Data.REQUEST_REFERENCE_NUMBER;
	           SET OutputRoot.DFDL.Request.body.ACCOUNT_NUMBER =  InputRoot.JSON.Data.ACCOUNT_NUMBER;
	           
	         DECLARE CBSString CHARACTER CAST(ASBITSTREAM(OutputRoot.DFDL CCSID 1208) AS CHARACTER CCSID 1208); 
	    	CALL Logger.LOGGER('Request Sent to CBS+' || CBSString,Env );	  
	    
		SET Environment."X-TxnDetails".TxnDetails='CBS';
		SET Environment."X-TxnDetails".TxnType='MR';
		SET Environment."X-TxnDetails".TxnSubType='E0';
		CALL EIS_API_LOGGER.EISLOGGING('X-TxnDetails+' ,Env) ;
	END;
END MODULE;







BROKER SCHEMA EIS_API_LOGGER


CREATE COMPUTE MODULE MR_SourceMapper_MR_Writing
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		SET OutputRoot = InputRoot;
		SET OutputLocalEnvironment = InputLocalEnvironment ;
		DECLARE Env REFERENCE TO Environment;
		--For Testing Only

		DECLARE CBS_REGION CHARACTER ;
--		SET CBS_REGION = COALESCE(EIS_API_LOGGER_Utility.getCacheValueFromWXS('SYSTEM.BROKER.DEFAULTMAP',COALESCE( OutputRoot.JSON.Data.SOURCE_ID,Environment."X-InputRequest".SOURCE_ID,Environment.SOURCE_ID) || '_REGION'),NULL);
--		SET Environment.CBSIP = COALESCE(EIS_API_LOGGER_Utility.getCacheValueFromWXS('SYSTEM.BROKER.DEFAULTMAP', CBS_REGION || '_IP'),NULL);
--		SET Environment.MRPORT = COALESCE(EIS_API_LOGGER_Utility.getCacheValueFromWXS('SYSTEM.BROKER.DEFAULTMAP', 'MR' || CBS_REGION || '_PORT'),NULL);

		SET CBS_REGION = COALESCE(EIS_API_LOGGER_Utility.getCacheValueFromWXS('GENERIC_LIB_CACHE',COALESCE( OutputRoot.JSON.Data.SOURCE_ID,Environment."X-InputRequest".SOURCE_ID,Environment.SOURCE_ID) || '_REGION'),EIS_API_LOGGER_Utility.getCacheValueFromWXS('SYSTEM.BROKER.DEFAULTMAP',COALESCE( OutputRoot.JSON.Data.SOURCE_ID,Environment."X-InputRequest".SOURCE_ID,Environment.SOURCE_ID) || '_REGION'),NULL);
		SET Environment.CBSIP = COALESCE(EIS_API_LOGGER_Utility.getCacheValueFromWXS('GENERIC_LIB_CACHE', CBS_REGION || '_IP'),EIS_API_LOGGER_Utility.getCacheValueFromWXS('SYSTEM.BROKER.DEFAULTMAP', CBS_REGION || '_IP'),NULL);
		SET Environment.MRPORT = COALESCE(EIS_API_LOGGER_Utility.getCacheValueFromWXS('GENERIC_LIB_CACHE', 'MR' || CBS_REGION || '_PORT'),EIS_API_LOGGER_Utility.getCacheValueFromWXS('SYSTEM.BROKER.DEFAULTMAP', 'MR' || CBS_REGION || '_PORT'),NULL);

		IF CONTAINS(CBS_REGION,'JavaError') OR CONTAINS(Environment.CBSIP,'JavaError') OR CONTAINS(Environment.MRPORT,'JavaError')THEN
			DELETE FIELD Environment.CBSIP;
			DELETE FIELD Environment.MRPORT;
		END IF;

		SET OutputLocalEnvironment.Destination.TCPIP.Output.Hostname = Environment.CBSIP;
		SET OutputLocalEnvironment.Destination.TCPIP.Output.Port = Environment.MRPORT;
		SET Environment.CBSPORT = Environment.MRPORT;

		SET OutputLocalEnvironment.TCPIP.Receive.Hostname = Environment.CBSIP;
		SET OutputLocalEnvironment.TCPIP.Receive.Port = Environment.MRPORT;

		SET Environment."X-DestinationDetails".MR_REGION = OutputLocalEnvironment.Destination.TCPIP.Output.Hostname || ':' || OutputLocalEnvironment.Destination.TCPIP.Output.Port ;
		--For Testing Only

		DECLARE CBSString CHARACTER CAST(ASBITSTREAM(InputRoot.DFDL CCSID COALESCE(InputRoot.Properties.CodedCharSetId,5348) Encoding COALESCE(InputRoot.Properties.Encoding,546)) AS CHARACTER CCSID COALESCE(InputRoot.Properties.CodedCharSetId,5348) Encoding COALESCE(InputRoot.Properties.Encoding,546));
		DECLARE CBSReqTranCode CHARACTER SUBSTRING(CBSString FROM 6 FOR 2);

		SET Environment."X-DestinationDetails".MsgType = 'MR' ;
		SET Environment."X-DestinationDetails"."Request TranCode" = CBSReqTranCode ;
		CALL EISLOGGING('X-DestinationDetails+' ,Env) ;
		CALL EISLOGGING('Request Sent to CBS+' || CBSString,Env);
		RETURN TRUE;
	END;

END MODULE;
