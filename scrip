CREATE COMPUTE MODULE postUpdate_Compute3
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE Env REFERENCE to Environment;
		SET Env.Flag=COALESCE(Env.Flag,'Y');
		
		IF Env.Flag='N' THEN
			DECLARE fileRef REFERENCE TO Environment.Res.File[1];
			CREATE FIELD OutputRoot.JSON.Data.Validation IDENTITY (JSON.Array)Validation;
			DECLARE i INTEGER 1;
		    WHILE LASTMOVE(fileRef) DO
		    	SET OutputRoot.JSON.Data.Validation[i].Filename = fileRef.FileName;
		    	SET OutputRoot.JSON.Data.Validation[i].FileContent = fileRef.FileContent ;
		    	SET i= i+1;
		    	MOVE fileRef NEXTSIBLING;
			END WHILE;
			RETURN true;
		ELSE
			SET Env.Res.File[Env.i].FileName = InputRoot.JSON.Data.File.FileName;
			SET Env.Res.File[Env.i].FileContent = InputRoot.JSON.Data.File.FileContent;
			SET Env.i=Env.i+1;
			RETURN false;
		END IF;
	END;
END MODULE;




CREATE COMPUTE MODULE postUpdate_Compute1
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
	    CREATE LASTCHILD OF Environment DOMAIN('JSON');
	    SET OutputRoot.JSON.Data.File.FileName = InputLocalEnvironment.File.Read.Name ;
	    SET OutputRoot.JSON.Data.File.FileContent = CAST(InputRoot.BLOB.BLOB AS CHARACTER CCSID COALESCE(InputRoot.Properties.CodedCharSetId ,5348)  ENCODING COALESCE(InputRoot.Properties.Encoding ,546)) ;
	    
		RETURN TRUE;
	END;

	
END MODULE;




