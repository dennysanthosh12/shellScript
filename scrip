CREATE COMPUTE MODULE CacheLoader_MQ
    CREATE FUNCTION Main() RETURNS BOOLEAN
    BEGIN

        DECLARE gCache REFERENCE TO MbGlobalMap;
        SET gCache = MbGlobalMap.getGlobalMap('MY_EMBEDDED_CACHE');

        DECLARE i INTEGER 1;
        DECLARE item REFERENCE TO InputRoot.JSON.Data.Item[i];

        WHILE LASTMOVE(item) DO

            SET gCache.{item.FIELD_NAME} = item.FIELD_VALUE;

            SET i = i + 1;
            SET item REFERENCE TO InputRoot.JSON.Data.Item[i];

        END WHILE;

        SET OutputRoot.JSON.Data.RESPONSE = 'success';

        RETURN TRUE;
    END;
END MODULE;
