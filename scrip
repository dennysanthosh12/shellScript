CREATE COMPUTE MODULE postUpdate_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE Env REFERENCE to Environment;
		CREATE LASTCHILD OF Env DOMAIN'XMLNSC';
		CREATE LASTCHILD OF Env.XMLNSC NAME 'Validation';
		SET Environment.Variables.FilePath = CAST('/var/mqsi/components/' || InputRoot.JSON.Data.IntegrationNode || '/servers/' || InputRoot.JSON.Data.IntegrationServer || '/run/' || InputRoot.JSON.Data.ApiName AS CHARACTER);
	    SET Environment.Variables.Pattern = '*.xsd' ;
	    SET Env.i=1;
	    
		RETURN TRUE;
	END;

END MODULE;




CREATE COMPUTE MODULE postUpdate_Compute2
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		declare Env REFERENCE to Environment;
		SET OutputRoot = InputRoot;
		set Env.Flag='N';
		RETURN TRUE;
	END;

END MODULE;




CREATE COMPUTE MODULE postUpdate_Compute3
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE Env REFERENCE to Environment;
		DECLARE EnvVal REFERENCE TO Environment.XMLNSC.Validation;
		SET Env.Flag=COALESCE(Env.Flag,'Y');
		
		IF Env.Flag='N' THEN
			MOVE EnvVal FIRSTCHILD;
			CREATE LASTCHILD OF OutputRoot DOMAIN('XMLNSC');
			CREATE LASTCHILD OF OutputRoot.XMLNSC NAME 'Validation';
			DECLARE outXmRef REFERENCE TO OutputRoot.XMLNSC.Validation;
		    WHILE LASTMOVE(EnvVal) DO
		    	CREATE LASTCHILD OF outXmRef NAME 'File';
				MOVE outXmRef LASTCHILD;
		    	SET outXmRef.FileName = EnvVal.FileName;
		    	CREATE LASTCHILD OF outXmRef NAME 'FileContent';
		    	MOVE outXmRef LASTCHILD;
		    	SET outXmRef = EnvVal.FileContent;
		    	MOVE EnvVal NEXTSIBLING;
			END WHILE;
			RETURN true;
		ELSE
			CREATE LASTCHILD OF EnvVal NAME 'File';
			MOVE EnvVal LASTCHILD;
			SET EnvVal.FileName = InputLocalEnvironment.File.Read.Name;
			CREATE LASTCHILD OF EnvVal NAME 'FileContent';
			MOVE EnvVal LASTCHILD;
			CREATE LASTCHILD OF EnvVal DOMAIN 'XMLNSC' PARSE(InputRoot.BLOB.BLOB ENCODING COALESCE(InputRoot.Properties.Encoding,546) CCSID COALESCE(InputRoot.Properties.CodedCharSetId,5348));
			RETURN false;
		END IF;
	END;
END MODULE;
