

CREATE COMPUTE MODULE postEndpoint_Compute
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE host1 CHARACTER;
		SET host1 = InputRoot.JSON.Data.host;
		DECLARE port1 CHARACTER;
		SET port1 = InputRoot.JSON.Data.port;
		DECLARE counts INTEGER 0;
		
		SELECT COUNT(*) INTO counts FROM Database.node_endpoint WHERE host = host1 AND port = port1;
		
		IF counts > 0 THEN
			SET OutputRoot.JSON.Data.Status = "Failed";
			SET OutputRoot.JSON.Data.Message = "Host and port alredy exist";
			PROPAGATE TO TERMINAL "out1";
		ELSE
			PROPAGATE;
			
		END IF;		 
		
		RETURN FALSE;
	END;

END MODULE;
