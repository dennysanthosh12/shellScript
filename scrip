public void evaluate(MbMessageAssembly inAssembly) throws MbException {
    MbOutputTerminal out = getOutputTerminal("out");
    MbOutputTerminal alt = getOutputTerminal("alternate");

    MbMessage inMessage = inAssembly.getMessage();
    MbMessageAssembly outAssembly = null;
    try {
        // create new message as a copy of the input
        MbMessage outMessage = new MbMessage(inMessage);
        outAssembly = new MbMessageAssembly(inAssembly, outMessage);

        // ----------------------------------------------------------
        // Add user code below

        // 1. Read FilePath from Environment
        MbElement envElement = inAssembly.getGlobalEnvironment().getRootElement();
        MbElement filePathElement = envElement.getFirstElementByPath("Variables/FilePath");

        if (filePathElement == null) {
            throw new MbUserException(this, "evaluate()", "", "",
                "FilePath not found in Environment/Variables/FilePath", null);
        }

        String filePath = (String) filePathElement.getValue();

        // 2. List files in the directory
        java.io.File directory = new java.io.File(filePath);

        if (!directory.exists() || !directory.isDirectory()) {
            // Propagate to alternate terminal if path is invalid
            alt.propagate(outAssembly);
            return;
        }

        java.io.File[] files = directory.listFiles();

        // 3. Build LocalEnvironment.Files.File[n] structure
        MbElement localEnv = outAssembly.getLocalEnvironment().getRootElement();

        // Ensure "Files" folder exists
        MbElement filesFolder = localEnv.getFirstElementByPath("Files");
        if (filesFolder == null) {
            filesFolder = localEnv.createElementAsLastChild(MbElement.TYPE_NAME, "Files", null);
        }

        if (files != null) {
            java.text.SimpleDateFormat sdf = new java.text.SimpleDateFormat("yyyy-MM-dd'T'HH:mm:ss");

            for (java.io.File file : files) {
                // Create a File element for each entry
                MbElement fileElement = filesFolder.createElementAsLastChild(
                    MbElement.TYPE_NAME, "File", null);

                // Directory (true/false as String)
                fileElement.createElementAsLastChild(
                    MbElement.TYPE_NAME_VALUE, "Directory",
                    String.valueOf(file.isDirectory()));

                // Name (filename only)
                fileElement.createElementAsLastChild(
                    MbElement.TYPE_NAME_VALUE, "Name",
                    file.getName());

                // LastModified as formatted timestamp
                String lastModified = sdf.format(new java.util.Date(file.lastModified()));
                fileElement.createElementAsLastChild(
                    MbElement.TYPE_NAME_VALUE, "LastModified",
                    lastModified);
            }
        }

        // End of user code
        // ----------------------------------------------------------
    } catch (MbException e) {
        throw e;
    } catch (RuntimeException e) {
        throw e;
    } catch (Exception e) {
        throw new MbUserException(this, "evaluate()", "", "", e.toString(), null);
    }

    out.propagate(outAssembly);
}
