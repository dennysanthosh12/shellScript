

CREATE COMPUTE MODULE postVote_Compute1
	CREATE FUNCTION Main() RETURNS BOOLEAN
	BEGIN
		DECLARE exp REFERENCE TO InputExceptionList.*[1];
		DECLARE ErrorNum CHARACTER ;
		DECLARE ErrorText CHARACTER ;
		CREATE LASTCHILD OF OutputRoot DOMAIN 'JSON';

    	SET OutputLocalEnvironment.Destination.HTTP.ReplyStatusCode = 400;

		WHILE LASTMOVE(exp) DO
			SET ErrorNum = exp.Number;
    		SET ErrorText = exp.Text; 
    		MOVE exp LASTCHILD;
		END WHILE;
    	SET OutputRoot.JSON.Data.error = 'BIP' || CAST(ErrorNum AS CHARACTER) || ': ' || ErrorText;

    RETURN TRUE; 
		RETURN TRUE;
	END;
END MODULE;


