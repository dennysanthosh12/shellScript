
- name: Set permissions and ownership for multiple files
  ansible.builtin.file:
    path: "{{ item.path }}"
    owner: "{{ item.owner }}"
    group: "{{ item.group }}"
    mode: "{{ item.mode }}"
  loop:
    - { path: "/etc/myapp/config.conf", owner: "myuser", group: "mygroup", mode: "0644" }
    - { path: "/var/log/myapp.log", owner: "appuser", group: "appgroup", mode: "0755" }
    - { path: "/opt/myapp/script.sh", owner: "root", group: "root", mode: "0700" }
