- name: Configure MAC policy audit rules
  copy:
    dest: /etc/audit/rules.d/MAC-policy.rules
    content: |
      -w /etc/selinux/ -p wa -k MAC-policy
      -w /usr/share/selinux/ -p wa -k MAC-policy
    owner: root
    group: root
    mode: "0640"

- name: Reload audit rules
  command: augenrules --load
